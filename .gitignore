# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production & build
/build
/dist

# debug & logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (always keep ignored to prevent credentials leakage)
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/app/generated/prisma
*.db
*.db-journal
*.sqlite

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs / Editors
.vscode/
.idea/
*.swp
*.swo
*.suo
*.sln

# Secrets & Certificates
*.pem
*.key
*.pub
*.cert
*.pfx
credentials.json
client_secret*.json
